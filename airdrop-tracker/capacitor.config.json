{
  "appId": "com.airdroptracker.app",
  "appName": "Airdrop Tracker",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchBackgroundColor": "#6366f1",
      "launchFadeOutDuration": 300,
      "androidSplashResourceName": "splash",
      "androidSplashTheme": "@style/AppTheme.NoActionBarLaunch",
      "showSplashScreenSpinner": false
    }
  }
}
